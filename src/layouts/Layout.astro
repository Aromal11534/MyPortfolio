---
import '../styles/global.css';

export interface Props {
  title: string;
  xData?: string;
  xInit?: string;
}

const { title, xData = "app()", xInit } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" x-data={xData} x-init={xInit} :class="{'dark':dark}" class="scroll-smooth">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="S. Aromal — Tech Enthusiast, Computer Specialist, and Founder at Syncify Edutech Solutions.">
<meta name="keywords" content="S. Aromal, Syncify, IoT Development, AI Systems, Web Development, Portfolio">
<meta name="author" content="S. Aromal">
<meta property="og:title" content="S. Aromal — Tech Enthusiast & Computer Specialist">
<meta property="og:description" content="Passionate about exploring innovative solutions that blend creativity and technology.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://aromal.syncify.in">
<title>{title.replace('Eliott', 'S. Aromal')}</title>
<link rel="icon" type="image/svg+xml" href="/sa-favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=PT+Sans:ital,wght@0,400;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
</head>

<body class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 antialiased">
  <slot />
  <slot name="script" />
</body>
</html>
