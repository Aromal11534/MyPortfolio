---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="index — Eliott" xData="app()">
  <Header activePath="/" />
  <main>
    <!-- ═══ HERO ═══ -->
    <section
      id="hero"
      class="relative min-h-screen flex items-center pt-16 overflow-hidden"
    >
      <div
        class="absolute top-1/4 right-0 w-96 h-96 bg-accent/10 rounded-full blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute bottom-1/4 left-0 w-64 h-64 bg-zinc-200/50 dark:bg-zinc-800/30 rounded-full blur-3xl pointer-events-none"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 py-24 w-full">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <p
              class="reveal text-sm font-medium text-accent tracking-widest uppercase mb-4"
            >
              Available for work
            </p>
            <h1
              class="reveal d1 font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[1.05] tracking-tight text-zinc-900 dark:text-white mb-6"
            >
              Hi, I'm <span class="text-accent">S. Aromal</span>
            </h1>
            <p
              class="reveal d2 text-lg md:text-xl text-zinc-500 dark:text-zinc-400 font-light leading-relaxed max-w-md mb-10"
            >
              <strong class="font-medium text-zinc-700 dark:text-zinc-300"
                >Co-Founder at Syncify Edutech Solutions</strong
              ><br /> Tech Enthusiast &amp; Computer Specialist. Passionate about
              exploring innovative solutions that blend creativity and technology.
            </p>
            <div class="reveal d3 flex flex-wrap gap-4">
              <a
                href="#work"
                class="shimmer inline-flex items-center gap-2 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 font-medium px-7 py-3.5 rounded-full hover:bg-zinc-700 dark:hover:bg-zinc-200 transition-colors text-sm"
              >
                View my work
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path></svg
                >
              </a>
              <a
                href="#contact"
                class="inline-flex items-center gap-2 border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 font-medium px-7 py-3.5 rounded-full hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-colors text-sm"
                >Get in touch</a
              >
            </div>
            <div
              class="reveal d4 flex gap-8 mt-14 pt-8 border-t border-zinc-100 dark:border-zinc-900"
            >
              <div>
                <p
                  class="font-display font-bold text-3xl text-zinc-900 dark:text-white"
                >
                  2+
                </p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">
                  Years experience
                </p>
              </div>
              <div>
                <p
                  class="font-display font-bold text-3xl text-zinc-900 dark:text-white"
                >
                  10+
                </p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">
                  Projects done
                </p>
              </div>
              <div>
                <p
                  class="font-display font-bold text-3xl text-zinc-900 dark:text-white"
                >
                  5+
                </p><p class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">
                  Certifications
                </p>
              </div>
            </div>
          </div>

          <div class="reveal d2 flex justify-center md:justify-end">
            <div class="relative w-72 h-72 md:w-80 md:h-80 lg:w-96 lg:h-96">
              <div class="pf w-full h-full rounded-3xl">
                <img
                  src="/assets/images/coat-dress.png"
                  alt="S. Aromal"
                  loading="eager"
                  class="object-cover w-full h-full"
                />
              </div>
              <div
                class="absolute -bottom-4 -left-4 bg-accent text-white font-display font-bold text-sm px-4 py-2.5 rounded-2xl shadow-lg"
              >
                Open to projects
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SERVICES ═══ -->
    <section
      id="services"
      class="py-24 bg-gradient-to-b from-transparent via-zinc-50/50 to-transparent dark:via-zinc-900/20"
    >
      <div class="max-w-6xl mx-auto px-6">
        <div class="mb-14">
          <p
            class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3"
          >
            What I do
          </p>
          <h2
            class="reveal d1 font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white"
          >
            Services
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <article
            class="reveal d1 card-h group bg-white/60 dark:bg-zinc-900/40 backdrop-blur-xl rounded-2xl p-8 border border-white/40 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div
              class="w-12 h-12 flex items-center justify-center bg-orange-50 dark:bg-zinc-800 rounded-xl mb-6 group-hover:bg-accent/10 transition-colors"
            >
              <svg
                class="w-6 h-6 text-accent"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg
              >
            </div>
            <h3
              class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3"
            >
              Software & Web Development
            </h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
              End-to-end software and web development. Expertise in website
              hosting, cloud application development, cloud infrastructure support
              (GCP, OCI), and robust system design.
            </p>
          </article>

          <article
            class="reveal d2 card-h group bg-zinc-900/90 dark:bg-zinc-800/60 backdrop-blur-xl rounded-2xl p-8 border border-zinc-700/50 shadow-[0_8px_30px_rgb(0,0,0,0.12)] hover:border-accent"
          >
            <div
              class="w-12 h-12 flex items-center justify-center bg-zinc-800 dark:bg-zinc-700 rounded-xl mb-6 group-hover:bg-accent/20 transition-colors"
            >
              <svg
                class="w-6 h-6 text-accent"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
              >
            </div>
            <h3 class="font-display font-bold text-xl text-white mb-3">
              IoT & Hardware Assembly
            </h3>
            <p class="text-sm text-zinc-400 leading-relaxed">
              Developing custom IoT applications using Raspberry Pi, ESP32, and
              Arduino. Comprehensive services in PC hardware assembly,
              networking, and hardware system integration.
            </p>
          </article>

          <article
            class="reveal d3 card-h group bg-white/60 dark:bg-zinc-900/40 backdrop-blur-xl rounded-2xl p-8 border border-white/40 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div
              class="w-12 h-12 flex items-center justify-center bg-orange-50 dark:bg-zinc-800 rounded-xl mb-6 group-hover:bg-accent/10 transition-colors"
            >
              <svg
                class="w-6 h-6 text-accent"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"
                ></path></svg
              >
            </div>
            <h3
              class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-3"
            >
              AI & ML Applications
            </h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">
              Developing intelligent AI systems and ML applications, from
              computer vision (OpenCV) to NLP. Specializing in advanced AI
              workflows and modern EdTech integration.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ═══ WORK ═══ -->
    <section id="work" class="py-24" x-data="{ showAll: false }">
      <div class="max-w-6xl mx-auto px-6">
        <div
          class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14"
        >
          <div>
            <p
              class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3"
            >
              Portfolio
            </p>
            <h2
              class="reveal d1 font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white"
            >
              Selected work
            </h2>
          </div>
          <a
            href="/projects"
            class="reveal d1 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-accent transition-colors self-start sm:self-auto nl"
            >All projects →</a
          >
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <article
            class="card-h reveal d1 group rounded-2xl overflow-hidden bg-zinc-50/80 dark:bg-zinc-900/50 backdrop-blur-xl border border-white/50 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent md:row-span-2"
          >
            <div class="pf w-full h-64 md:h-80">
              <img
                src="/assets/images/syncify-erp.png"
                alt="AI Campus ERP System"
                loading="lazy"
                class="object-cover object-top w-full h-full transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-7">
              <div class="flex flex-wrap gap-2 mb-5">
                <span class="text-xs bg-orange-50 dark:bg-zinc-800 text-accent border border-orange-200 dark:border-zinc-700 px-3 py-1 rounded-full">AI/ML</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Full-Stack Dev</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">SaaS</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">EdTech</span>
              </div>
              <div class="flex items-center gap-4 mb-3">
                <div class="h-12 w-12 flex-shrink-0 bg-white dark:bg-zinc-800 rounded-lg p-2 border border-zinc-200 dark:border-zinc-700 flex items-center justify-center shadow-sm">
                  <img src="/assets/logos/syncify%20transparent.png" alt="Syncify Logo" class="max-h-full max-w-full object-contain" />
                </div>
                <a href="https://www.syncify.in" target="_blank" rel="noopener noreferrer">
                  <h3 class="font-display font-bold text-2xl text-zinc-900 dark:text-white hover:text-accent transition-colors">
                    AI Campus ERP System
                  </h3>
                </a>
              </div>
              <div class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-5 space-y-4">
                <p>
                  A comprehensive AI-powered Enterprise Resource Planning (ERP) platform designed for colleges and educational institutions. The system centralizes academic administration, student management, attendance tracking, examination workflows, and institutional analytics into a single cloud-based platform.
                </p>
                <p>
                  Beyond traditional ERP functionality, the platform incorporates Artificial Intelligence to analyze academic performance, predict student outcomes, assess skill development, and generate actionable insights for educators and administrators. Students can build dynamic skill profiles through certification analysis, while institutions gain data-driven tools to improve academic success, employability, and placement outcomes.
                </p>

              </div>
              <a
                href="https://www.syncify.in" target="_blank" rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white nl"
                >View project <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  aria-hidden="true"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                ></a
              >
            </div>
          </article>

          <article
            class="card-h reveal d2 group rounded-2xl overflow-hidden bg-zinc-50/80 dark:bg-zinc-900/50 backdrop-blur-xl border border-white/50 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div class="pf w-full h-48">
              <img
                src="/assets/images/kiducode-img.png"
                alt="KiduCode AI Coding Agent"
                loading="lazy"
                class="object-cover object-center w-full h-full transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs bg-orange-50 dark:bg-zinc-800 text-accent border border-orange-200 dark:border-zinc-700 px-3 py-1 rounded-full">AI Agent</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">CLI</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Open Source</span>
              </div>
              <div class="flex items-center gap-3 mb-2">
                <div class="h-10 w-10 flex-shrink-0 bg-white dark:bg-zinc-800 rounded-lg p-1.5 border border-zinc-200 dark:border-zinc-700 flex items-center justify-center shadow-sm">
                  <img src="/assets/logos/kiducode.png" alt="KiduCode Logo" class="max-h-full max-w-full object-contain" />
                </div>
                <a href="https://www.kiducode.com" target="_blank" rel="noopener noreferrer">
                  <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white hover:text-accent transition-colors">
                    KiduCode
                  </h3>
                </a>
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                A Kerala-built open-source AI coding agent with Manglish and Malayalam prompt support. Code in English. Prompt in Manglish. Think in Malayalam.
              </p>
              <div class="flex items-center gap-4">
                <a href="https://www.kiducode.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white nl">
                  Visit website →
                </a>
                <a href="https://github.com/Aromal11534/Beehive-Music" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
                  GitHub
                </a>
              </div>
            </div>
          </article>

          <article
            class="card-h reveal d3 group rounded-2xl overflow-hidden bg-zinc-50/80 dark:bg-zinc-900/50 backdrop-blur-xl border border-white/50 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div class="pf w-full h-48">
              <img
                src="/assets/images/beehive.png"
                alt="Beehive Music"
                loading="lazy"
                class="object-cover object-center w-full h-full transition-transform duration-500 group-hover:scale-105"
              />
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-4">
                <span class="text-xs bg-orange-50 dark:bg-zinc-800 text-accent border border-orange-200 dark:border-zinc-700 px-3 py-1 rounded-full">Python</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Discord API</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Bot</span>
              </div>
              <div class="flex items-center gap-3 mb-2">
                <div class="h-10 w-10 flex-shrink-0 bg-white dark:bg-zinc-800 rounded-lg p-1.5 border border-zinc-200 dark:border-zinc-700 flex items-center justify-center shadow-sm">
                  <img src="/assets/logos/beehive.png" alt="Beehive Music Logo" class="max-h-full max-w-full object-contain" />
                </div>
                <a href="https://github.com/Aromal11534/Music-Bot" target="_blank" rel="noopener noreferrer">
                  <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white hover:text-accent transition-colors">
                    Beehive Music
                  </h3>
                </a>
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                A feature-rich Discord music bot for high-quality audio streaming, playlist management, and seamless music playback in voice channels.
              </p>
              <a href="https://github.com/Aromal11534/Music-Bot" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white nl">
                View on GitHub →
              </a>
            </div>
          </article>

          <!-- Extra Project 1: Kiducode -->
          <article
            x-show="showAll"
            x-cloak
            x-transition.opacity.duration.500ms
            class="card-h group rounded-2xl overflow-hidden bg-zinc-50/80 dark:bg-zinc-900/50 backdrop-blur-xl border border-white/50 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div class="pf w-full h-48">
              <img
                src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=800&q=80"
                alt="Kiducode Open Source Coding Agent"
                loading="lazy"
                class="object-cover w-full h-full"
              />
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="text-xs bg-orange-50 dark:bg-zinc-800 text-accent border border-orange-200 dark:border-zinc-700 px-3 py-1 rounded-full">Open Source</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">AI/ML</span>
              </div>
              <a href="/case-study">
                <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-1.5">
                  Kiducode Agent
                </h3>
              </a>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                An open-source coding agent designed to assist developers in automating coding tasks efficiently.
              </p>
              <a href="/case-study" class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white nl">View case study →</a>
            </div>
          </article>

          <!-- Extra Project 2: CRPF Resident Management -->
          <article
            x-show="showAll"
            x-cloak
            x-transition.opacity.duration.500ms
            class="card-h group rounded-2xl overflow-hidden bg-zinc-50/80 dark:bg-zinc-900/50 backdrop-blur-xl border border-white/50 dark:border-zinc-800/50 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:border-accent"
          >
            <div class="pf w-full h-48">
              <img
                src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80"
                alt="CRPF Resident Management App"
                loading="lazy"
                class="object-cover w-full h-full"
              />
            </div>
            <div class="p-6">
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="text-xs bg-orange-50 dark:bg-zinc-800 text-accent border border-orange-200 dark:border-zinc-700 px-3 py-1 rounded-full">Full Stack</span>
                <span class="text-xs bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-3 py-1 rounded-full">Database</span>
              </div>
              <a href="/case-study">
                <h3 class="font-display font-bold text-xl text-zinc-900 dark:text-white mb-1.5">
                  CRPF Resident App
                </h3>
              </a>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4">
                A comprehensive application for managing resident data, access, and administration for the Central Reserve Police Force.
              </p>
              <a href="/case-study" class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-900 dark:text-white nl">View case study →</a>
            </div>
          </article>

        </div>

        <div class="mt-12 flex justify-center">
          <button @click="showAll = !showAll" class="inline-flex items-center gap-2 border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 font-medium px-7 py-3 rounded-full hover:bg-zinc-50 dark:hover:bg-zinc-900 transition-colors text-sm cursor-pointer">
            <span x-text="showAll ? 'Show less' : 'Show more'"></span>
            <svg x-show="!showAll" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            <svg x-show="showAll" x-cloak class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
          </button>
        </div>
      </div>
    </section>

    <!-- ═══ ABOUT ═══ -->
    <section
      id="about"
      class="py-24 bg-gradient-to-b from-transparent via-zinc-50/50 to-transparent dark:via-zinc-900/20"
    >
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
          <div class="reveal order-2 md:order-1">
            <div class="pf w-full aspect-square max-w-sm mx-auto rounded-3xl">
              <img
                src="/assets/images/coat-dress.png"
                alt="S. Aromal"
                loading="lazy"
                class="object-cover w-full h-full"
              />
            </div>
          </div>

          <div class="order-1 md:order-2">
            <p
              class="reveal text-xs font-medium text-accent tracking-widest uppercase mb-3"
            >
              About me
            </p>
            <h2
              class="reveal d1 font-display font-bold text-4xl md:text-5xl text-zinc-900 dark:text-white leading-tight mb-6"
            >
              A bit about<br />who I am
            </h2>
            <p
              class="reveal d2 text-zinc-500 dark:text-zinc-400 leading-relaxed mb-4"
            >
              I'm S. Aromal, a tech enthusiast with a deep love for computers
              and innovative technology solutions. Currently pursuing my
              Bachelor's degree in Technology at Valia Koonambaikulathamma
              College of Engineering and Technology, I thrive on exploring
              cutting-edge developments in computer science.
            </p>
            <p
              class="reveal d3 text-zinc-500 dark:text-zinc-400 leading-relaxed mb-8"
